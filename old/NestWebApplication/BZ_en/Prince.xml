<?xml version="1.0" encoding="windows-1250"?>
<!DOCTYPE base SYSTEM "base.dtd">
<base>
 <global>
  <description>Prince</description>
  <expert>PB</expert>
  <date>4.6.2003</date>
  <inference_mechanism>standard</inference_mechanism>
  <weight_range>3</weight_range>
  <default_weight>irrelevant</default_weight>
  <global_priority>first</global_priority>
  <context_global_threshold>1,500</context_global_threshold>
  <condition_global_threshold>0,000</condition_global_threshold>
 </global>
 <attributes>
  <attribute>
   <id>prince</id>
   <name>Prince</name>
   <type>binary</type>
   <comment>Is it a prince?</comment>
  </attribute>
  <attribute>
   <id>size_of_foot</id>
   <name>What is the size of adept's foot?</name>
   <type>numeric</type>
   <legal_values>
    <lower_bound>0,000</lower_bound>
    <upper_bound>50,000</upper_bound>
   </legal_values>
   <comment>Prince has to have small foot.</comment>
   <propositions>
    <proposition>
     <id>small_foot</id>
     <name>Small foot</name>
     <weight_function>
      <fuzzy_lower_bound>0,000</fuzzy_lower_bound>
      <crisp_lower_bound>0,000</crisp_lower_bound>
      <crisp_upper_bound>39,000</crisp_upper_bound>
      <fuzzy_upper_bound>41,000</fuzzy_upper_bound>
     </weight_function>
    </proposition>
    <proposition>
     <id>medium_foot</id>
     <name>Medium foot</name>
     <weight_function>
      <fuzzy_lower_bound>39,000</fuzzy_lower_bound>
      <crisp_lower_bound>41,000</crisp_lower_bound>
      <crisp_upper_bound>42,000</crisp_upper_bound>
      <fuzzy_upper_bound>44,000</fuzzy_upper_bound>
     </weight_function>
    </proposition>
    <proposition>
     <id>big_foot</id>
     <name>Big foot</name>
     <weight_function>
      <fuzzy_lower_bound>42,000</fuzzy_lower_bound>
      <crisp_lower_bound>44,000</crisp_lower_bound>
      <crisp_upper_bound>50,000</crisp_upper_bound>
      <fuzzy_upper_bound>50,000</fuzzy_upper_bound>
     </weight_function>
    </proposition>
   </propositions>
  </attribute>
  <attribute>
   <id>good_family</id>
   <name>good family</name>
   <type>binary</type>
   <comment>Prince has to be from good family</comment>
  </attribute>
  <attribute>
   <id>blue_blood</id>
   <name>Blue blood</name>
   <type>binary</type>
   <comment>Aristrocrat has to have blue blood</comment>
  </attribute>
  <attribute>
   <id>wealthy_family</id>
   <name>Wealthy family</name>
   <type>binary</type>
   <comment>Prince has to come from wealthy family</comment>
  </attribute>
  <attribute>
   <id>property</id>
   <name>Property</name>
   <type>multiple</type>
   <propositions>
    <proposition>
     <id>money</id>
     <name>Money</name>
    </proposition>
    <proposition>
     <id>lots</id>
     <name>Lots</name>
    </proposition>
   </propositions>
  </attribute>
 </attributes>
 <contexts>
  <context>
   <id>CTX1</id>
   <condition>
    <conjunction>
     <literal>
      <id_attribute>size_of_foot</id_attribute>
      <id_proposition>small_foot</id_proposition>
      <negation>0</negation>
     </literal>
    </conjunction>
   </condition>
  </context>
 </contexts>
 <rules>
  <apriori_rules>
  </apriori_rules>
  <logical_rules>
   <logical_rule>
    <id>l1</id>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>size_of_foot</id_attribute>
      <id_proposition>big_foot</id_proposition>
      <negation>0</negation>
     </literal>
    </conjunction>
    <conjunction>
     <literal>
      <id_attribute>size_of_foot</id_attribute>
      <id_proposition>medium_foot</id_proposition>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>prince</id_attribute>
      <negation>1</negation>
     </conclusion>
    </conclusions>
   </logical_rule>
   <logical_rule>
    <id>l2</id>
    <id_context>CTX1</id_context>
    <context_threshold>0,500</context_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>good_family</id_attribute>
      <negation>1</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>prince</id_attribute>
      <negation>1</negation>
     </conclusion>
    </conclusions>
   </logical_rule>
   <logical_rule>
    <id>l3</id>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>blue_blood</id_attribute>
      <negation>1</negation>
     </literal>
    </conjunction>
    <conjunction>
     <literal>
      <id_attribute>wealthy_family</id_attribute>
      <negation>1</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>good_family</id_attribute>
      <negation>1</negation>
     </conclusion>
    </conclusions>
   </logical_rule>
   <logical_rule>
    <id>l4</id>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>property</id_attribute>
      <id_proposition>money</id_proposition>
      <negation>1</negation>
     </literal>
     <literal>
      <id_attribute>property</id_attribute>
      <id_proposition>lots</id_proposition>
      <negation>1</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>wealthy_family</id_attribute>
      <negation>1</negation>
     </conclusion>
    </conclusions>
   </logical_rule>
  </logical_rules>
  <compositional_rules>
   <compositional_rule>
    <id>c1</id>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>size_of_foot</id_attribute>
      <id_proposition>small_foot</id_proposition>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>good_family</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>prince</id_attribute>
      <negation>0</negation>
      <weight>3,000</weight>
     </conclusion>
    </conclusions>
   </compositional_rule>
   <compositional_rule>
    <id>c2</id>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>blue_blood</id_attribute>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>wealthy_family</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>good_family</id_attribute>
      <negation>0</negation>
      <weight>3,000</weight>
     </conclusion>
    </conclusions>
   </compositional_rule>
   <compositional_rule>
    <id>c3</id>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>property</id_attribute>
      <id_proposition>money</id_proposition>
      <negation>0</negation>
     </literal>
    </conjunction>
    <conjunction>
     <literal>
      <id_attribute>property</id_attribute>
      <id_proposition>lots</id_proposition>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>wealthy_family</id_attribute>
      <negation>0</negation>
      <weight>3,000</weight>
     </conclusion>
    </conclusions>
   </compositional_rule>
  </compositional_rules>
 </rules>
