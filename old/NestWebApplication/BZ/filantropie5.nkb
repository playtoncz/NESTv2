<!--******************** Rules ********************-->

 <rules>

<!--******************** Apriori rules ********************-->

  <apriori_rules>
  </apriori_rules>

<!--******************** Logical rules ********************-->

  <logical_rules>

   <logical_rule>
    <id>zamit_nic</id>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>zadatel</id_attribute>
      <id_proposition>nic</id_proposition>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>zamitnout</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>P_opr_zad</id>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>zadatel</id_attribute>
      <id_proposition>jednotlivec</id_proposition>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>zdrav_post</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    <conjunction>
     <literal>
      <id_attribute>zadatel</id_attribute>
      <id_proposition>neziskovka</id_proposition>
      <negation>0</negation>
     </literal>
    </conjunction>
    <conjunction>
     <literal>
      <id_attribute>zadatel</id_attribute>
      <id_proposition>VPA</id_proposition>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>opr_zad</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>not_zdr_pos</id>
    <id_context>K_ZP_jednotlivec</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>zdrav_post</id_attribute>
      <negation>1</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>zamitnout</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>not_opr_zad</id>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>opr_zad</id_attribute>
      <negation>1</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>zamitnout</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>PA_1</id>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>opr_zad</id_attribute>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>pred_spol</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>PA1</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>pul_roku</id>
    <id_context>K_PA1</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>pul_rok</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>zamitnout</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>PA_5</id>
    <id_context>K_PA1</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>PA1</id_attribute>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>pul_rok</id_attribute>
      <negation>1</negation>
     </literal>
     <literal>
      <id_attribute>posl_rok</id_attribute>
      <negation>1</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>PA5</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>PA_3</id>
    <id_context>K_PA1&amp;posl_rok</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>kolik</id_attribute>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>PA2</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>PA3</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>not_kolik</id>
    <id_context>K_PA2</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>kolik</id_attribute>
      <negation>1</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>zamitnout</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>PA_4</id>
    <id_context>K_opr_zad</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>pred_spol</id_attribute>
      <negation>1</negation>
     </literal>
     <literal>
      <id_attribute>obor_cin</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>PA4</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>not_obor_cin</id>
    <id_context>K_not_pred_spol</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>obor_cin</id_attribute>
      <negation>1</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>zamitnout</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>financni_1</id>
    <id_context>K_PA5</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>pozadavek1</id_attribute>
      <id_proposition>financni1</id_proposition>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>do5_1</id_attribute>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>PA5</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>fin_dar</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>financni_2</id>
    <id_context>K_PA4</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>PA4</id_attribute>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>pozadavek1</id_attribute>
      <id_proposition>financni1</id_proposition>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>do5_1</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>fin_dar</id_attribute>
      <negation>0</negation>
