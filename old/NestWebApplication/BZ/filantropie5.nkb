   <logical_rule>
    <id>indiv_pos1</id>
    <id_context>K_PA3</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>pozadavek2</id_attribute>
      <id_proposition>financni2</id_proposition>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>do5_2</id_attribute>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>PA3</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>indiv_pos</id_attribute>
      <negation>0</negation>
