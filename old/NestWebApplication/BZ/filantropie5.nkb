   <logical_rule>
    <id>indiv_pos2</id>
    <id_context>K_PA7</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
    <conjunction>
     <literal>
      <id_attribute>do10</id_attribute>
      <negation>0</negation>
     </literal>
     <literal>
      <id_attribute>PA7</id_attribute>
      <negation>0</negation>
     </literal>
    </conjunction>
    </condition>
    <conclusions>
     <conclusion>
      <id_attribute>indiv_pos</id_attribute>
      <negation>0</negation>
     </conclusion>
    </conclusions>
   </logical_rule>

   <logical_rule>
    <id>indiv_pos3</id>
    <id_context>K_PA4</id_context>
    <condition_threshold>0,000</condition_threshold>
    <condition>
