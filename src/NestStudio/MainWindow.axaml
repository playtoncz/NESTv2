<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NestStudio.MainWindow"
        Title="NEST Studio"
        Width="1100" Height="900"
        MinWidth="900" MinHeight="600">
  <Border Classes="panel" Margin="16" Padding="12">
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto">
      <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
        <TextBlock Classes="title" Text="NEST Studio" />
        <TextBlock Text="Konzultace / Runner" Opacity="0.7" Margin="0,2,0,0" />
      </StackPanel>

      <!-- Panel s informací o nové verzi vpravo od titulku -->
      <Border x:Name="UpdatePanel"
              Grid.Row="0"
              Grid.Column="1"
              Background="{DynamicResource UpdateBannerBgBrush}"
              BorderBrush="{DynamicResource UpdateBannerBorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10,6"
              MaxWidth="700"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="16,0,0,0"
              IsVisible="False">
        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock x:Name="UpdateText"
                     Text="K dispozici je nová verze."
                     FontSize="12"
                     Margin="0,0,8,0"
                     TextWrapping="Wrap" />
          <Button x:Name="UpdateDownloadButton"
                  Content="Stáhnout aktualizaci"
                  Padding="8,2"
                  FontSize="11"
                  Margin="0,0,6,0"
                  Click="OnUpdateDownloadClick" />
          <Button x:Name="UpdateChangelogButton"
                  Content="Zobrazit changelog"
                  Padding="8,2"
                  FontSize="11"
                  Click="OnUpdateChangelogClick" />
        </WrapPanel>
      </Border>

      <ContentControl x:Name="MainContent"
                      Grid.Row="1"
                      Grid.ColumnSpan="2"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource GlassPanelBgBrush}" />
    </Grid>
  </Border>
</Window>
