<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NestStudio.MainWindow"
        Title="NEST Studio"
        Width="900" Height="650"
        MinWidth="700" MinHeight="500">
  <Border Classes="panel" Margin="24">
    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
      <StackPanel Grid.Row="0" Margin="0,0,0,16">
        <TextBlock Classes="title" Text="NEST Studio" />
        <TextBlock Text="Konzultace / Runner" Opacity="0.7" Margin="0,4,0,0" />
      </StackPanel>
      <ContentControl x:Name="MainContent" Grid.Row="1" />
    </Grid>
  </Border>
</Window>
