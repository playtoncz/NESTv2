<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NestStudio.Views.KbEditorView">
  <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
      <Button x:Name="BackButton" Content="← Zpět" />
      <TextBlock x:Name="TitleText" Text="Editor znalostní báze" VerticalAlignment="Center" FontWeight="SemiBold" />
      <Button x:Name="SaveButton" Content="Uložit XML" Classes="primary" />
      <Button x:Name="FillProjectButton" Content="Vyplnit projekt" />
      <Button x:Name="ValidateButton" Content="Validace" />
      <Button x:Name="GraphButton" Content="Graf pravidel" />
      <Button x:Name="GlobalPropsButton" Content="Globální vlastnosti" />
      <Button x:Name="StatisticsButton" Content="Statistiky" />
      <TextBlock x:Name="StatusText" Text="" VerticalAlignment="Center" Opacity="0.8" Margin="8,0,0,0" />
    </StackPanel>
    <Grid Grid.Row="1" ColumnDefinitions="280,*" RowDefinitions="*">
      <Grid Grid.Column="0" RowDefinitions="Auto,130,Auto,*,Auto,90,Auto,80" Margin="0,0,8,0">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Atributy" FontWeight="SemiBold" Margin="0,0,0,4" VerticalAlignment="Center" />
          <Button x:Name="NewAttributeButton" Content="Nový atribut" Padding="6,2" />
        </StackPanel>
        <ListBox x:Name="AttributesList" Grid.Row="1" SelectionMode="Single" />
        <TextBlock Text="Pravidla" FontWeight="SemiBold" Margin="0,12,0,4" Grid.Row="2" />
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,0,0,0">
          <ListBox x:Name="RulesList" Grid.Column="0" SelectionMode="Single" MinHeight="80" />
          <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0" VerticalAlignment="Top">
            <Button x:Name="NewRuleButton" Content="Nové pravidlo" Padding="6,2" />
            <Button x:Name="DeleteRuleButton" Content="Smazat" Padding="6,2" />
          </StackPanel>
        </Grid>
        <TextBlock Text="Kontexty" FontWeight="SemiBold" Margin="0,12,0,4" Grid.Row="4" />
        <Grid Grid.Row="5" ColumnDefinitions="*,Auto">
          <ListBox x:Name="ContextsList" Grid.Column="0" SelectionMode="Single" MinHeight="60" />
          <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0" VerticalAlignment="Top">
            <Button x:Name="NewContextButton" Content="Nový kontext" Padding="6,2" />
            <Button x:Name="DeleteContextButton" Content="Smazat" Padding="6,2" />
          </StackPanel>
        </Grid>
        <TextBlock Text="Integritní omezení" FontWeight="SemiBold" Margin="0,12,0,4" Grid.Row="6" />
        <Grid Grid.Row="7" ColumnDefinitions="*,Auto">
          <ListBox x:Name="IntegrityList" Grid.Column="0" SelectionMode="Single" MinHeight="60" />
          <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0" VerticalAlignment="Top">
            <Button x:Name="NewIntegrityButton" Content="Nové IO" Padding="6,2" />
            <Button x:Name="DeleteIntegrityButton" Content="Smazat" Padding="6,2" />
          </StackPanel>
        </Grid>
      </Grid>
      <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12">
        <ContentControl x:Name="DetailContent" />
      </Border>
    </Grid>
  </Grid>
</UserControl>
