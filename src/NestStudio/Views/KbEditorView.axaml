<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NestStudio.Views.KbEditorView">
  <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
    <!-- Toolbar -->
    <Border Grid.Row="0" Classes="editor-toolbar">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button x:Name="BackButton" Content="← Zpět" />
          <TextBlock x:Name="TitleText" Text="Editor znalostní báze" VerticalAlignment="Center"
                     FontWeight="SemiBold" FontSize="16" Foreground="#1E293B" Margin="8,0,0,0" />
        </StackPanel>
        <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="SaveButton" Content="Uložit XML" Classes="primary" Margin="0,0,6,0" />
          <Button x:Name="FillProjectButton" Content="Vyplnit projekt" Margin="0,0,6,0" />
          <Button x:Name="ValidateButton" Content="Validace" Margin="0,0,6,0" />
          <Button x:Name="GraphButton" Content="Graf pravidel" Margin="0,0,6,0" />
          <Button x:Name="GlobalPropsButton" Content="Globální vlastnosti" Margin="0,0,6,0" />
          <Button x:Name="StatisticsButton" Content="Statistiky" />
          <TextBlock x:Name="StatusText" Text="" VerticalAlignment="Center" Opacity="0.7"
                     FontSize="12" Margin="12,0,0,0" Foreground="#64748B" />
        </WrapPanel>
      </Grid>
    </Border>
    <!-- Main content -->
    <Grid Grid.Row="1" ColumnDefinitions="260,*" Margin="0,0,0,0">
      <!-- Sidebar -->
      <Border Grid.Column="0" Classes="editor-sidebar" Margin="0,0,10,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="0">
            <!-- Atributy -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="ATRIBUTY" Classes="sidebar-heading" VerticalAlignment="Center" />
              <Button x:Name="NewAttributeButton" Content="+ Nový" FontSize="11" Padding="8,3" />
              <Button x:Name="DeleteAttributeButton" Content="Smazat" FontSize="11" Padding="8,3" />
            </StackPanel>
            <ListBox x:Name="AttributesList" SelectionMode="Single" MinHeight="80" MaxHeight="180" />

            <!-- Pravidla -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="PRAVIDLA" Classes="sidebar-heading" VerticalAlignment="Center" />
              <Button x:Name="NewRuleButton" Content="+ Nové" FontSize="11" Padding="8,3" />
              <Button x:Name="DeleteRuleButton" Content="Smazat" FontSize="11" Padding="8,3" />
            </StackPanel>
            <ListBox x:Name="RulesList" SelectionMode="Single" MinHeight="60" MaxHeight="200" />

            <!-- Kontexty -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="KONTEXTY" Classes="sidebar-heading" VerticalAlignment="Center" />
              <Button x:Name="NewContextButton" Content="+ Nový" FontSize="11" Padding="8,3" />
              <Button x:Name="DeleteContextButton" Content="Smazat" FontSize="11" Padding="8,3" />
            </StackPanel>
            <ListBox x:Name="ContextsList" SelectionMode="Single" MinHeight="40" MaxHeight="100" />

            <!-- Integritní omezení -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="INTEGRITNÍ OMEZENÍ" Classes="sidebar-heading" VerticalAlignment="Center" />
              <Button x:Name="NewIntegrityButton" Content="+ Nové" FontSize="11" Padding="8,3" />
              <Button x:Name="DeleteIntegrityButton" Content="Smazat" FontSize="11" Padding="8,3" />
            </StackPanel>
            <ListBox x:Name="IntegrityList" SelectionMode="Single" MinHeight="40" MaxHeight="100" />
          </StackPanel>
        </ScrollViewer>
      </Border>
      <!-- Detail -->
      <Border Grid.Column="1" Classes="editor-detail">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <ContentControl x:Name="DetailContent" />
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>
