<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NestStudio.Views.WelcomeView">
  <StackPanel Spacing="20">
    <TextBlock Text="Vítejte v NEST Studio" FontSize="18" FontWeight="SemiBold" />
    <TextBlock Text="Otevřete znalostní bázi (XML) nebo spusťte konzultaci s již načtenou KB." TextWrapping="Wrap" MaxWidth="500" />
    <StackPanel Spacing="12" Orientation="Horizontal">
      <Button x:Name="OpenKbButton" Content="Otevřít znalostní bázi..." Classes="primary" />
      <Button x:Name="RunConsultationButton" Content="Spustit konzultaci" IsEnabled="False" />
      <Button x:Name="OpenEditorButton" Content="Otevřít v editoru" IsEnabled="False" />
    </StackPanel>
    <TextBlock x:Name="StatusText" Text="" Opacity="0.8" />
  </StackPanel>
</UserControl>
