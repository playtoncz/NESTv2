<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NestStudio.Views.ConsultationView">
  <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
    <Border Grid.Row="0" Grid.ColumnSpan="2" Classes="consultation-header" Margin="0,0,0,16">
      <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Button x:Name="BackButton" Content="← Zpět" Margin="0,0,16,0" />
        <TextBlock x:Name="TitleText" Text="Konzultace" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="18" />
      </WrapPanel>
    </Border>
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,-8">
    <Grid ColumnDefinitions="1.2*,*" Margin="0,0,0,0" MinWidth="500">
      <Border Grid.Column="0" Classes="glass-panel" Padding="20" Margin="0,0,12,0">
        <Grid RowDefinitions="*,Auto">
          <ScrollViewer Grid.Row="0" Margin="0,0,4,0" HorizontalScrollBarVisibility="Auto">
            <StackPanel x:Name="QuestionnairePanel" Spacing="0" Margin="0,0,8,0" />
          </ScrollViewer>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
            <Button x:Name="RunButton" Content="Spustit inference" Classes="primary" />
            <Button x:Name="ExportResultButton" Content="Export výsledku (XML)" IsEnabled="False" />
          </StackPanel>
        </Grid>
      </Border>
      <Border Grid.Column="1" Classes="glass-panel" Padding="20" Margin="12,0,0,0">
        <Grid RowDefinitions="Auto,*">
          <TextBlock x:Name="ResultsTitle" Text="Výsledky inference" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,12" IsVisible="False" />
          <ScrollViewer Grid.Row="1">
            <StackPanel x:Name="ResultsPanel" Spacing="6" />
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
    </ScrollViewer>
  </Grid>
</UserControl>
