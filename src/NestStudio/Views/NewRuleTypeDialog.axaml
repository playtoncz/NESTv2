<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NestStudio.Views.NewRuleTypeDialog"
        Title="Nové pravidlo"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
  <Border Classes="glass-panel" Margin="16" Padding="24">
    <StackPanel Spacing="16">
      <TextBlock Text="Typ pravidla" FontWeight="SemiBold" FontSize="15" Foreground="#334155" />
      <ComboBox x:Name="TypeCombo" MinWidth="280" CornerRadius="10" Padding="12,10"
                BorderBrush="#E2E8F0" BorderThickness="1" SelectedIndex="0">
        <ComboBoxItem Content="Kompozicionální (váhy −1 až 1)" />
        <ComboBoxItem Content="Apriorní (vždy platí, bez podmínek)" />
        <ComboBoxItem Content="Logické (pravda / nepravda)" />
      </ComboBox>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,8,0,0">
        <Button x:Name="CancelButton" Content="Zrušit" />
        <Button x:Name="OkButton" Content="Vytvořit" Classes="primary" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
