<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NestStudio.Views.NewAttributeTypeDialog"
        Title="Nový atribut – výběr typu"
        Width="360" Height="180"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="24" Spacing="16">
    <TextBlock Text="Typ atributu:" FontWeight="SemiBold" />
    <ComboBox x:Name="TypeCombo" MinWidth="200" SelectedIndex="0">
      <ComboBoxItem Content="Binary (ano/ne)" />
      <ComboBoxItem Content="Single (jeden výběr)" />
      <ComboBoxItem Content="Set / Multiple (více výběrů)" />
      <ComboBoxItem Content="Numeric (číselná hodnota)" />
    </ComboBox>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,12,0,0">
      <Button x:Name="CancelButton" Content="Zrušit" />
      <Button x:Name="OkButton" Content="OK" Classes="primary" />
    </StackPanel>
  </StackPanel>
</Window>
