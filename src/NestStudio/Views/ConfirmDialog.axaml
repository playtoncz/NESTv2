<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NestStudio.Views.ConfirmDialog"
        Title="Potvrdit"
        Width="360" Height="140"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="24" Spacing="20">
    <TextBlock x:Name="MessageText" Text="" TextWrapping="Wrap" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
      <Button x:Name="NoButton" Content="Ne" />
      <Button x:Name="YesButton" Content="Ano" Classes="primary" />
    </StackPanel>
  </StackPanel>
</Window>
