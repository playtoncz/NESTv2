<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NestStudio.Views.SaveChangesDialog"
        Title="Neuložené změny"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBgBrush}">
  <Border Classes="glass-panel" Margin="16" Padding="24">
    <StackPanel Spacing="18">
      <TextBlock Text="Neuložené změny"
                 FontWeight="SemiBold"
                 FontSize="15"
                 Foreground="{DynamicResource DialogTitleFgBrush}" />
      <TextBlock Text="Máte neuložené změny. Chcete je před odchodem uložit?"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource DialogLabelFgBrush}" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
        <Button x:Name="CancelButton" Content="Zrušit" />
        <Button x:Name="DiscardButton" Content="Neukládat" />
        <Button x:Name="SaveButton" Content="Uložit" Classes="primary" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
