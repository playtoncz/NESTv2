<Project>
  <!-- Portable win-x64 single-file .exe. Po publikaci doporučujeme podepsat .exe (SignTool + certifikát),
       jinak Windows 11 Inteligentní řízení aplikací může zablokovat spuštění. Viz docs/Podepisování-a-Windows-Smart-App-Control.md -->
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>
</Project>

